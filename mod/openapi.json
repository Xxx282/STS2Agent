{
  "openapi": "3.0.0",
  "info": {
    "title": "STS2Agent API",
    "description": "Slay the Spire 2 智能代理接口 - 获取游戏状态信息",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8888",
      "description": "游戏内服务器"
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "summary": "健康检查",
        "description": "检查服务状态",
        "responses": {
          "200": {
            "description": "健康状态",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/state": {
      "get": {
        "summary": "完整游戏状态",
        "description": "获取当前游戏完整状态信息",
        "responses": {
          "200": {
            "description": "游戏状态",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GameState"
                }
              }
            }
          }
        }
      }
    },
    "/api/player": {
      "get": {
        "summary": "玩家状态",
        "description": "获取当前玩家状态",
        "responses": {
          "200": {
            "description": "玩家状态",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlayerState"
                }
              }
            }
          }
        }
      }
    },
    "/api/enemies": {
      "get": {
        "summary": "敌人状态列表",
        "description": "获取所有敌人状态",
        "responses": {
          "200": {
            "description": "敌人列表",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/EnemyState"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/combat": {
      "get": {
        "summary": "战斗状态",
        "description": "获取当前战斗状态",
        "responses": {
          "200": {
            "description": "战斗状态",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CombatState"
                }
              }
            }
          }
        }
      }
    },
    "/api/CardReward": {
      "get": {
        "summary": "卡牌奖励状态",
        "description": "获取当前卡牌奖励界面状态和可选卡牌列表。客户端轮询此接口以检测奖励界面出现。",
        "responses": {
          "200": {
            "description": "卡牌奖励信息",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CardRewardInfo"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "healthy"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "version": {
            "type": "string",
            "example": "1.0.0"
          },
          "inGame": {
            "type": "boolean"
          },
          "inCombat": {
            "type": "boolean"
          }
        }
      },
      "GameState": {
        "type": "object",
        "properties": {
          "inGame": {
            "type": "boolean",
            "description": "是否在游戏中"
          },
          "inCombat": {
            "type": "boolean",
            "description": "是否在战斗中"
          },
          "floor": {
            "type": "integer",
            "description": "当前层数"
          },
          "turn": {
            "type": "integer",
            "description": "当前回合数"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "player": {
            "$ref": "#/components/schemas/PlayerState"
          },
          "enemies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EnemyState"
            }
          },
          "combat": {
            "$ref": "#/components/schemas/CombatState"
          }
        }
      },
      "PlayerState": {
        "type": "object",
        "properties": {
          "currentHealth": {
            "type": "integer",
            "description": "当前生命值"
          },
          "maxHealth": {
            "type": "integer",
            "description": "最大生命值"
          },
          "block": {
            "type": "integer",
            "description": "当前护甲"
          },
          "energy": {
            "type": "integer",
            "description": "当前能量"
          },
          "maxEnergy": {
            "type": "integer",
            "description": "最大能量"
          },
          "stars": {
            "type": "integer",
            "description": "星币数量"
          },
          "gold": {
            "type": "integer",
            "description": "金币数量"
          },
          "potionCount": {
            "type": "integer",
            "description": "药水数量"
          },
          "potions": {
            "type": "array",
            "description": "药水列表",
            "items": {
              "type": "string"
            }
          },
          "orbCount": {
            "type": "integer",
            "description": "充能球数量"
          },
          "orbCapacity": {
            "type": "integer",
            "description": "充能球容量"
          },
          "orbs": {
            "type": "array",
            "description": "充能球列表",
            "items": {
              "$ref": "#/components/schemas/OrbInfo"
            }
          },
          "hand": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "手牌列表"
          },
          "drawPile": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "抽牌堆"
          },
          "discardPile": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "弃牌堆"
          },
          "exhaustPile": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "耗尽堆"
          },
          "powers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "当前能力"
          }
        }
      },
      "OrbInfo": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "充能球名称"
          }
        }
      },
      "EnemyState": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "敌人唯一标识"
          },
          "name": {
            "type": "string",
            "description": "敌人名称"
          },
          "currentHealth": {
            "type": "integer",
            "description": "当前生命值"
          },
          "maxHealth": {
            "type": "integer",
            "description": "最大生命值"
          },
          "block": {
            "type": "integer",
            "description": "当前护甲"
          },
          "intent": {
            "type": "string",
            "description": "意图类型 (Attack/Defense/Buff等)"
          },
          "intentAmount": {
            "type": "integer",
            "description": "意图数值"
          },
          "powers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "当前能力"
          }
        }
      },
      "CombatState": {
        "type": "object",
        "properties": {
          "turn": {
            "type": "integer",
            "description": "战斗回合数"
          },
          "isPlayerTurn": {
            "type": "boolean",
            "description": "是否为玩家回合"
          },
          "canPlayCard": {
            "type": "boolean",
            "description": "是否可以出牌"
          },
          "canEndTurn": {
            "type": "boolean",
            "description": "是否可以结束回合"
          }
        }
      },
      "CardRewardInfo": {
        "type": "object",
        "properties": {
          "hasReward": {
            "type": "boolean",
            "description": "是否有卡牌奖励"
          },
          "isVisible": {
            "type": "boolean",
            "description": "卡牌奖励界面是否显示"
          },
          "canReroll": {
            "type": "boolean",
            "description": "是否可以重投"
          },
          "canSkip": {
            "type": "boolean",
            "description": "是否可以跳过"
          },
          "cards": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RewardCardInfo"
            }
          }
        }
      },
      "RewardCardInfo": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "卡牌显示名称（中文本地化）"
          },
          "cost": {
            "type": "integer",
            "description": "能量费用"
          },
          "rarity": {
            "type": "string",
            "description": "稀有度：Common / Uncommon / Rare"
          },
          "type": {
            "type": "string",
            "description": "卡牌类型：Attack / Skill / Power"
          },
          "isUpgraded": {
            "type": "boolean",
            "description": "是否已升级"
          },
          "pickRate": {
            "type": "number",
            "nullable": true,
            "description": "场外选牌率（%）"
          },
          "winRateDelta": {
            "type": "number",
            "nullable": true,
            "description": "场外胜率差值（%）"
          },
          "skadaScore": {
            "type": "number",
            "nullable": true,
            "description": "场外评分（综合评分）"
          },
          "rank": {
            "type": "integer",
            "nullable": true,
            "description": "场外排名"
          },
          "confidence": {
            "type": "string",
            "nullable": true,
            "description": "数据可信度：low / medium / high"
          }
        }
      }
    }
  }
}
